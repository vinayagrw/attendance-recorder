{
  "name": "attendance-recorder",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "concurrently --names \"vite,fns\" --prefix-colors \"cyan,magenta\" --kill-others-on-fail \"pnpm --filter @attendance/web dev\" \"npx supabase functions serve --no-verify-jwt\"",
    "dev:vite": "pnpm --filter @attendance/web dev",
    "dev:functions": "npx supabase functions serve --no-verify-jwt",
    "dev:cloud": "pnpm --filter @attendance/web exec vite --mode cloud",
    "tunnel": "ngrok http 5173",
    "build": "pnpm --filter @attendance/web build",
    "build:cloud": "pnpm --filter @attendance/web exec vite build --mode cloud",
    "preview": "pnpm --filter @attendance/web preview",
    "typecheck": "pnpm --filter @attendance/web typecheck",
    "typecheck:functions": "pnpm --filter @attendance/web exec tsc -p ../../supabase/functions/tsconfig.json",
    "test:e2e": "pnpm --filter @attendance/web test:e2e",
    "supabase:start": "npx supabase start --ignore-health-check",
    "supabase:stop": "npx supabase stop",
    "supabase:reset": "npx supabase db reset"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "supabase"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "supabase": "^2.98.0"
  }
}
