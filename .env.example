# Copy to apps/web/.env.local for local dev.
# Get values from Supabase dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Service-side (used by Edge Functions only — set with `supabase secrets set`,
# never put in the .env consumed by the browser).
# SUPABASE_SERVICE_ROLE_KEY=...
# SUPABASE_JWT_SECRET=...
