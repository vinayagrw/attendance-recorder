# Copy this file to apps/web/.env.local and fill in real values.
# .env.local is gitignored; keep the real keys out of source control.
#
# Two scenarios:
#
# A) LOCAL DEV (Docker via `supabase start`)
#    Use the URL + anon key printed by the CLI when the local stack starts.
#    Typically:
#      NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#      NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<anon key from CLI output>
#
# B) CLOUD DEV / PROD (your hosted Supabase project)
#    Get values from the Supabase dashboard → Project Settings → API.
#      NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
#      NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
#
# C) PHONE TESTING via ngrok tunnel (HTTPS, real device)
#    `pnpm tunnel` exposes the Vite dev server (port 5173) at an HTTPS URL.
#    Vite proxies /rest/v1, /auth/v1, /storage/v1, /realtime/v1, /functions/v1
#    back to the local Supabase stack on 127.0.0.1:54321, so a single tunnel
#    URL serves both the PWA and the API. Set both env vars to that URL:
#      NEXT_PUBLIC_SUPABASE_URL=https://YOUR-STATIC-DOMAIN.ngrok-free.app
#      NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<same anon key as scenario A>
#    Required for camera + geolocation on real Android phones (secure context).
#
# vite.config.ts is configured to also accept the older VITE_* prefix:
#   VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY — use whichever style you prefer.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ─────────────────────────────────────────────────────────────────
# Optional behaviour overrides (defaults in apps/web/src/config/app.ts)
# Uncomment to override at build time. All are OPTIONAL.
# ─────────────────────────────────────────────────────────────────

# Responsive layout breakpoints (px)
# VITE_MOBILE_BREAKPOINT_PX=768
# VITE_DESKTOP_BREAKPOINT_PX=1024

# Selfie capture
# VITE_SELFIE_MAX_LONG_EDGE_PX=800
# VITE_SELFIE_JPEG_QUALITY=0.7
# VITE_CAMERA_READY_TIMEOUT_MS=3000

# Geolocation (client preview only — server enforces ATT_MAX_GPS_ACCURACY_M)
# VITE_GPS_TIMEOUT_MS=10000
# VITE_GPS_MAX_ACCURACY_M=100

# Traffic logger / refetch cadences (ms)
# VITE_TRAFFIC_LOGGER_DEBOUNCE_MS=250
# VITE_ATTENDANCE_REFETCH_MS=30000
# VITE_PENDING_APPROVALS_REFETCH_MS=60000
# VITE_TRAFFIC_REFETCH_MS=30000
# VITE_FEATURE_FLAG_TTL_MS=300000
